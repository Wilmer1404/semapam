# ##############################################################################
# Gitignore for Ionic Angular Capacitor Project
# ##############################################################################

# Node modules / dependency directories
node_modules/

# Angular build outputs and cache
/www/
/dist/
/.angular/
/out-tsc/
/tmp/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editor/IDE configurations
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS metadata files
.DS_Store
Thumbs.db

# Capacitor / Native Platforms
# ----------------------------
# Note: It is recommended to commit native platform directories (android, ios)
# to git, but ignore their build artifacts, local configurations, and sync'd assets.

# Android specific
/android/.gradle/
/android/local.properties
/android/build/
/android/app/build/
/android/app/src/main/assets/public/
/android/app/src/main/assets/capacitor.plugins.json
/android/app/src/main/assets/capacitor.config.json
/android/capacitor.settings.gradle

# iOS specific (in case iOS is added later)
/ios/.bundle/
/ios/Pods/
/ios/Podfile.lock
/ios/App/App/public/
/ios/App/App/capacitor.config.json
/ios/App/App/capacitor.plugins.json

# Environment / Secret configurations
.env
.env.*
! .env.example
src/environments/environment.local.ts

            "description": "Retorna todas las zonas publicadas."
          }
        },
        {
          "name": "Sincronizar Catálogos",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sync/catalogs",
              "host": ["{{base_url}}"],
              "path": ["sync", "catalogs"]
            },
            "description": "Retorna productos y zonas en un solo endpoint para sincronización offline."
          }
        }
      ]
    },
    {
      "name": "Abastecimientos",
      "item": [
        {
          "name": "Registrar Abastecimiento",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idLocal\": \"UUID-LOCAL-001\",\n  \"cantidad\": 20,\n  \"producto\": { \"id\": 1 },\n  \"recibidoPor\": \"María López\",\n  \"zonaNombreSnapshot\": \"Zona Norte\",\n  \"zonaId\": 1,\n  \"latitud\": -12.046374,\n  \"longitud\": -77.042793,\n  \"precisionGps\": 5.0,\n  \"fechaGps\": \"2026-04-05 08:00:00\",\n  \"importe\": 100.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/abastecimientos",
              "host": ["{{base_url}}"],
              "path": ["abastecimientos"]
            },
            "description": "Registra un nuevo abastecimiento. Campos requeridos: idLocal, cantidad, producto, conductor, recibidoPor, zonaNombreSnapshot, latitud, longitud, precisionGps, fechaGps, horaInicio, horaFin, importe."
          }
        },
        {
          "name": "Sincronizar Abastecimientos (batch)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"idLocal\": \"UUID-LOCAL-002\",\n      \"cantidad\": 10,\n      \"producto\": { \"id\": 1 },\n      \"recibidoPor\": \"María López\",\n      \"zonaNombreSnapshot\": \"Zona Norte\",\n      \"zonaId\": 1,\n      \"latitud\": -12.046374,\n      \"longitud\": -77.042793,\n      \"precisionGps\": 5.0,\n      \"fechaGps\": \"2026-04-05 07:00:00\",\n      \"importe\": 50.00\n    },\n    {\n      \"idLocal\": \"UUID-LOCAL-003\",\n      \"cantidad\": 15,\n      \"producto\": { \"id\": 2 },\n      \"recibidoPor\": \"Ana Torres\",\n      \"zonaNombreSnapshot\": \"Zona Sur\",\n      \"zonaId\": 2,\n      \"latitud\": -12.100000,\n      \"longitud\": -77.050000,\n      \"precisionGps\": 4.5,\n      \"fechaGps\": \"2026-04-05 09:00:00\",\n      \"importe\": 75.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/sync/abastecimientos",
              "host": ["{{base_url}}"],
              "path": ["sync", "abastecimientos"]
            },
            "description": "Sincroniza múltiples abastecimientos en lote (uso offline). Enviar un array en la propiedad `items`."
          }
        }
      ]
    },

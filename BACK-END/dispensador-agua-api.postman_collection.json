{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Dispensador de Agua API",
    "description": "Colección de endpoints para el backend del dispensador de agua.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:7636/backend-dispensador-agua-api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "var token = (json && json.data && json.data.token) ? json.data.token : null;",
                  "if (token) {",
                  "    pm.collectionVariables.set('token', token);",
                  "    pm.environment.set('token', token);",
                  "    pm.environment.set('token-rest-dispensador', token);",
                  "} else {",
                  "    console.warn('No se encontro data.token en la respuesta de login');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "description": "Autentica un usuario y retorna un JWT. El token se guarda automáticamente en la variable `token` de la colección."
          }
        },
        {
          "name": "Me (sesión actual)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "description": "Retorna los datos del usuario autenticado basándose en el JWT."
          }
        }
      ]
    },
    {
      "name": "Catálogos",
      "item": [
        {
          "name": "Listar Productos",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/catalogs/products",
              "host": ["{{base_url}}"],
              "path": ["catalogs", "products"]
            },
            "description": "Retorna todos los productos activos."
          }
        },
        {
          "name": "Listar Zonas",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/catalogs/zones",
              "host": ["{{base_url}}"],
              "path": ["catalogs", "zones"]
